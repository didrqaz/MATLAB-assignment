%(18)
clc; clear; clf;

A = [4 -1 2;
    1 3 -1
    2 -2 5];
b = [7 4 10]';

disp("9-18");
fprintf("A² =");
disp(A^2)

fprintf("A.² =");
disp(A.^2)%a
% A^2는 A에 A를 행렬곱한 결과를 반환한다.
% A.^2는 A의 원소가 제곱된 결과를 반환한다.

disp("det(A) =");
disp(det(A));%b
% (det(A) != 0)이므로 역행렬이 존재한다.

disp("inv(A)*b =");
disp(inv(A)*b);
disp("A\b =");
disp(A\b);%c
% (inv(A)*b == A\b) 이다.

% (d) Ax = b의 해는 A\b = [1.0465, 1.7442, 2.2791]'이다.

