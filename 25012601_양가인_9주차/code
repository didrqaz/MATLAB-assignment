%(12)
clc; clear; clf;

n = 1:1:30;
T1 = n;
T2 = n.*log(n);
T3 = n.^2;
T4 = 2.^n;

disp("9-12");
subplot(1,2,1);
plot(n,T1,n,T2,n,T3,n,T4);
title("Fig.12a");%a

subplot(1,2,2);
semilogy(n,T1,n,T2,n,T3,n,T4);
title("Fig.12b");%b
%log scale가 성장률 비교에 더 적절하다. 일반 plot으로 비교하면 n값이 커짐에 따라 함수값 사이의 격차가 기하급수적으로 늘어 비교가 어려우나, log scale로 비교하면 기하급수적인 격차도 한 눈에 들어오기 때문이다.

